PORT=5000
MONGODB_URI=mongodb://localhost:27017/growthminds

# ─── OpenRouter API Key ───────────────────────────────────────────────────────
# Get your free key at: https://openrouter.ai/keys
# OpenRouter provides a single API that routes to many AI models.
# Free-tier models are used by default — no payment required to start.
#
# Fallback chain (tried in order if a model fails):
#   1. Llama 3.3 70B  (meta-llama/llama-3.3-70b-instruct:free)
#   2. Gemma 4 31B    (google/gemma-4-31b-it:free)
#   3. Llama 3.2 3B   (meta-llama/llama-3.2-3b-instruct:free)
OPENROUTER_API_KEY=your_openrouter_api_key_here

CHANNEL_SERVICE_URL=http://localhost:6000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
