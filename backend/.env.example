# Backend Environment Variables
PORT=5000
NODE_ENV=development

# MongoDB Connection String (Atlas or Local)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/growthminds

# OpenRouter API Key for AI Segmentation
OPENROUTER_API_KEY=your_openrouter_api_key

# URL of the deployed Channel Service
CHANNEL_SERVICE_URL=https://your-channel-service.onrender.com

# URL of the deployed Frontend (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app
